        <div class="relative">
            <input type="text" name="q" x-ref="searchInput" x-model="query" @input.debounce.300ms="fetchSuggestions" @keydown.down.prevent="selectNext" @keydown.up.prevent="selectPrevious" @keydown.escape="open = false" value="" placeholder="Buscar logos..." class="w-full px-4 py-3 pr-12 text-gray-900 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
            <button type="submit" class="absolute right-2 top-1/2 -translate-y-1/2 p-2 text-gray-500 hover:text-gray-700">
